# ⚠️  Copy this to .env and fill in your values. Never commit .env to git.

# MongoDB connection string
MONGO_URI=

# Strong random secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=PLACEHOLDER_REPLACE_WITH_STRONG_SECRET

# Your frontend URL (in production: your Render URL)
CLIENT_URL=http://localhost:5173

PORT=5000
NODE_ENV=development

# Set to true when testing backend routes independently (Postman/REST Client)
# without running the frontend. Never set this in production.
CORS_ALL_ORIGINS=false
