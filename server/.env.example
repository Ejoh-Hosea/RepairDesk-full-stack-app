# ⚠️ Copy this to .env and fill in your values. Never commit .env to git.

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/repair-dashboard

# Strong random secret
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=PLACEHOLDER_REPLACE_WITH_STRONG_SECRET

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

PORT=5000
NODE_ENV=development

# Set true when testing backend routes independently (Postman/REST Client)
# Never set in production
CORS_ALL_ORIGINS=false

# Controls static file serving:
#   render → Express serves React build (Render single-service deployment)
#   aws    → API only, frontend on S3/CloudFront (never serve static files)
#   unset  → Local dev, Vite handles frontend on :5173
DEPLOYMENT_TARGET=
